      return setError("Password must be at least 6 characters.");
    setLoading(true);
    try {
      await axios.post("http://localhost:5000/api/users/register", {
        name: fullName,
        email: email,
        password: password,
        bloodGroup: "A+", // Default, TODO: Add blood group selection
        phone: "", // TODO: Add phone field to form
